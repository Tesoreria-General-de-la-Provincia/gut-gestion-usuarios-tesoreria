# Modo: "sqlite" (dev, datos seed) | "sqlserver" (prod)
GUT_MODO=sqlite

# Puerto del host expuesto por Docker (cambiar si 5000 está ocupado)
GUT_HOST_PORT=5000

# Verificación de red al iniciar el contenedor (opcional, solo loggea, no bloquea)
# Definí host + puerto del SQL Server (o cualquier otro target) y se prueba TCP al arrancar.
# Dejá vacío para deshabilitar.
GUT_NET_CHECK_HOST=
GUT_NET_CHECK_PORT=
GUT_NET_CHECK_TIMEOUT=5

# SQL Server (solo necesario si GUT_MODO=sqlserver)
GUT_DB_SERVER=host\instancia
GUT_DB_NAME=nombre_base
GUT_DB_USER=usuario
GUT_DB_PASSWORD=contraseña
